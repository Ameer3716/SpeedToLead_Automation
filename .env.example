# Copy this file to .env and fill in what you need.
# Anything left blank just stays in demo mode for that channel - nothing
# breaks, no real message goes out, no bill runs up.

# ============ CORE ============
# true = no real SMS/email is sent, everything is logged as "_demo" instead.
# Flip to false only once Twilio/SendGrid creds below are filled in.
DEMO_MODE=true

# Shared secret your webhooks (Zapier/n8n/Make/website form/Twilio) must send
# back as header "X-API-Key: <this>" or query param "?key=<this>".
# CHANGE THIS before going live - do not ship the default.
WEBHOOK_API_KEY=secret_key_123

# The public URL this app is reachable at once deployed. Used to build the
# /book/{id} link that goes out inside every SMS and email.
# Local dev: leave as-is. Render/Railway/prod: set to your real https:// URL.
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional: locks the dashboard + /leads /events /stats behind a single
# shared password (HTTP Basic Auth - browser will prompt for username +
# this password; username can be anything). Leave blank for an open demo
# link. SET THIS before putting a real client's real lead data online.
DASHBOARD_PASSWORD=

# ============ BUSINESS INFO (shown on dashboard + inside messages) ============
BUSINESS_NAME=Acme Home Services
BOOKING_LINK=https://calendly.com/your-real-link

# ============ SMS - Twilio (leave blank to stay in demo mode for SMS) ============
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_PHONE=+1234567890

# ============ EMAIL - SendGrid (leave blank to stay in demo mode for email) ============
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=sales@yourdomain.com

# ============ OWNER ALERTS (who gets pinged on every new lead + reminder) ============
# Set at least one of these three so the business owner actually gets notified.
OWNER_EMAIL=
OWNER_PHONE=
SLACK_WEBHOOK_URL=

# ============ TIMING ============
# Seconds to wait before nagging the owner if the lead still hasn't booked.
# 600 (10 min) matches the sales pitch. Drop to 20-30 for a live demo call
# so the client watches the reminder actually fire.
REMINDER_DELAY_SECONDS=600

# The "industry average" the dashboard compares your speed against.
# 169200 = 47 hours, cited in the outreach copy. Change if you use a
# different benchmark for a specific industry/client.
INDUSTRY_AVERAGE_RESPONSE_SECONDS=169200
